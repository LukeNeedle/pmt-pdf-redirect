{
    "name": "pmt-pdf-redirector",
    "version": "1.0.1",
    "description": "This extension redirects you to the pdf file on Physics and Maths Tutor's website based on the pdf that you are currently viewing.",
    "main": "src/background.js",
    "scripts": {
        "build": "webpack --mode production && npm run package-chrome-extension",
        "package-chrome-extension": "node ./scripts/package-chrome-extension.js"
    },    
    "keywords": [],
    "author": "Luke Needle",
    "devDependencies": {
        "webpack": "^5.90.3"
    },
    "files": [
        "manifest.json",
        "src/background.js",
        "src/content.js",
        "src/rules.json",
        "icon.png"
    ]
}
